DATABASE_URL=postgresql+asyncpg://fraud_user:fraud_pass@localhost:5435/fraud_detection
SYNC_DATABASE_URL=postgresql://fraud_user:fraud_pass@localhost:5435/fraud_detection

# Redis — point to tennis_redis (6379) or fraud-detection-redis (6380)
REDIS_URL=redis://localhost:6380

# Channel Project 1 publishes completed transactions on
TRANSACTION_CHANNEL=transactions:completed

# Fraud thresholds
VELOCITY_MAX_TX_PER_HOUR=10
AMOUNT_THRESHOLD=10000.00
ROUND_AMOUNT_THRESHOLD=1000.00
ML_CONTAMINATION=0.05
ML_ANOMALY_SCORE_THRESHOLD=-0.1
